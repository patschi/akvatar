{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [ "config:best-practices", "mergeConfidence:all-badges" ],
    "labels": ["renovate"],
    "assignees": ["pkernstock"],
    "automergeType": "branch",
    "vulnerabilityAlerts": {
        "enabled": true,
        "labels": ["security"],
        "automerge": true
    },
    "customManagers": [
        {
            "description": "Track uv version in UV_VERSION CI variable via PyPI. Groups with the Dockerfile COPY --from=ghcr.io/astral-sh/uv docker ref so both update in one PR.",
            "customType": "regex",
            "fileMatch": ["^\\.gitlab-ci\\.yml$"],
            "matchStrings": ["UV_VERSION: \"(?<currentValue>[^\"]+)\""],
            "depNameTemplate": "uv",
            "datasourceTemplate": "pypi"
        }
    ],
    "packageRules": [
        {
            "description": "Group Dockerfile uv image and CI uv PyPI pin into one PR so they always stay in sync.",
            "matchDepNames": ["ghcr.io/astral-sh/uv", "uv"],
            "groupName": "uv",
            "automerge": true
        },
        {
            "matchFileNames": [".gitlab-ci.yml"],
            "matchDatasources": ["docker"],
            "matchUpdateTypes": ["patch"],
            "automerge": true,
            "enabled": true
        },
        {
            "matchManagers": ["dockerfile", "docker-compose"],
            "matchDatasources": ["docker"],
            "matchUpdateTypes": ["patch"],
            "automerge": true
        },
        {
            "matchManagers": ["dockerfile", "gitlabci"],
            "matchDepNames": ["python"],
            "allowedVersions": "/^3\\.13/",
            "description": "Pin Python to 3.13.x across Dockerfile and CI to stay in sync with distroless/python3-debian13 (Debian Trixie). Bump this rule intentionally when moving to a new distroless base."
        },
        {
            "matchDatasources": ["docker"],
            "matchDepNames": ["gcr.io/distroless/python3-debian13"],
            "matchFileNames": ["Dockerfile"],
            "automerge": true,
            "enabled": true
        }
    ]
}
