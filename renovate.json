{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [ "config:best-practices", "mergeConfidence:all-badges" ],
    "labels": ["renovate"],
    "assignees": ["pkernstock"],
    "automergeType": "branch",
    "vulnerabilityAlerts": {
        "enabled": true,
        "labels": ["security"],
        "automerge": true
    },
    "packageRules": [
        {
            "matchFileNames": [".gitlab-ci.yml"],
            "matchDatasources": ["docker"],
            "matchUpdateTypes": ["patch"],
            "automerge": true,
            "enabled": true
        },
        {
            "matchManagers": ["dockerfile", "docker-compose"],
            "matchDatasources": ["docker"],
            "matchUpdateTypes": ["patch"],
            "automerge": true
        },
        {
            "matchManagers": ["dockerfile"],
            "matchDepNames": ["python"],
            "allowedVersions": "/^3\\.13/",
            "description": "Pin builder Python to 3.13.x to stay in sync with distroless/python3-debian13 (Debian Trixie). Bump this rule intentionally when moving to a new distroless base."
        },
        {
            "matchDatasources": ["docker"],
            "matchDepNames": ["gcr.io/distroless/python3-debian13"],
            "matchFileNames": ["Dockerfile"],
            "automerge": true,
            "enabled": true
        }
    ]
}
